# ─────────────────────────────────────────────
# ERP Starter Framework — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Application
NEXT_PUBLIC_APP_NAME="ERP Starter"
NEXT_PUBLIC_APP_VERSION="0.1.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/erp_starter"
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_SSL=false

# Authentication
# Generate secure secrets: openssl rand -hex 32
JWT_SECRET="your-jwt-secret-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-refresh-token-secret-different-from-jwt"

# Cookie domain (optional — leave blank for localhost)
# COOKIE_DOMAIN=".yourdomain.com"
